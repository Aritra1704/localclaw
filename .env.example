# Core runtime
NODE_ENV=development
DATABASE_URL=postgresql://postgres:password@localhost:5432/localclaw
DATABASE_SCHEMA=localclaw
SSD_BASE_PATH=/Volumes/Ari_SSD_01/PROJECTS/localclaw

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# GitHub
GITHUB_PAT=
GITHUB_USERNAME=
GITHUB_REPO_OWNER=
GITHUB_API_BASE_URL=https://api.github.com
GITHUB_REPO_VISIBILITY=private
GITHUB_AUTO_PUBLISH=false
GIT_DEFAULT_BRANCH=main

# Railway
RAILWAY_API_TOKEN=

# Ollama
OLLAMA_BASE_URL=http://127.0.0.1:11434
OLLAMA_KEEP_ALIVE=30s
MODEL_PLANNER=gemma4:e4b
MODEL_CODER=qwen2.5-coder:7b
MODEL_FAST=qwen2.5:7b-instruct
MODEL_REVIEW=gemma4:e4b
MODEL_EMBED=nomic-embed-text:latest

# Execution controls
TASK_POLL_INTERVAL_MS=30000
TASK_TIMEOUT_HOURS=2
MAX_CONSECUTIVE_FAILURES=3
DOCKER_SANDBOX_ENABLED=false
